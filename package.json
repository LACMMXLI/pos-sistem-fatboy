{
  "name": "fatboy-pos-root",
  "version": "1.0.0",
  "description": "Aplicacion de escritorio Fatboy POS para punto de venta e impresion ESC/POS en Windows.",
  "author": "Fatboy POS",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "backend": "npm --prefix backend run start:dev",
    "frontend": "npm --prefix frontend run dev",
    "whatsapp-addon": "npm --prefix whatsapp-addon run dev",
    "whatsapp-addon:build": "npm --prefix whatsapp-addon run build",
    "frontend:tablets": "npm --prefix frontend run dev -- --host 0.0.0.0",
    "frontend:build": "npm --prefix frontend run build",
    "dev": "start-dev.cmd",
    "dev:single": "concurrently -n \"BACKEND,FRONTEND\" -c \"blue,green\" \"npm run backend\" \"npm run frontend\"",
    "dev:tablets": "concurrently -n \"BACKEND,FRONTEND-LAN\" -c \"blue,green\" \"npm run backend\" \"npm run frontend:tablets\"",
    "desktop:dev": "concurrently -n \"BACKEND,FRONTEND,ELECTRON\" -c \"blue,green,yellow\" \"npm run backend\" \"npm run frontend\" \"wait-on tcp:3000 http://127.0.0.1:5173 && electron .\"",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "desktop:build": "npm run frontend:build",
    "desktop:package": "npm run desktop:build && node scripts/package-electron-app.cjs",
    "desktop:exe": "npm run desktop:package",
    "backend:installer": "build-backend-installer.cmd",
    "backend:installer:stage": "npm --prefix backend run build && node scripts/prepare-backend-installer.cjs",
    "backend:service:install": "npm --prefix backend run service:install",
    "backend:service:start": "npm --prefix backend run service:start",
    "backend:service:stop": "npm --prefix backend run service:stop",
    "backend:service:status": "npm --prefix backend run service:status",
    "backend:service:uninstall": "npm --prefix backend run service:uninstall",
    "desktop:pack": "npm run desktop:build && electron-forge package",
    "desktop:dist": "npm run desktop:build && electron-forge make"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "concurrently": "^8.2.2",
    "electron": "^37.10.3",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.0",
    "wait-on": "^8.0.3"
  }
}
